---
export interface Props {
    icon: string
    name: string
    description: string
    url: string
}

const { icon, name, description, url } = Astro.props;
---

<a
  href={url}
  target="_blank"
  class="p-5 border border-transparent rounded-lg h-full w-full duration-200 hover:(bg-[#EBEBEB] cursor-pointer dark:bg-[#1A1A1A])"
>
    <div class="flex flex-inline h-auto items-center">
        <div class="">
            <img
              src={icon}
              class="rounded-md h-28 w-28"
              alt="icon"
            />
        </div>
        <div class="">
            <p class="text-2xl text-primary font-semibold ml-5">{name}</p>
        </div>
    </div>
    <div class="h-auto">
        <p class="text-secondary">{description}</p>
    </div>
</a>
