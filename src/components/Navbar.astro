---
import ThemeToggle from "./ThemeToggle.astro";

interface NavbarItem {
    name: string;
    url: string;
}

const navbarItems: NavbarItem[] = [
    { name: "Home", url: "/" },
    { name: "Blog", url: "/blog" },
    { name: "Projects", url: "/projects" },
];
---

<nav class="border-b border-b-[#EAEAEA] bg-1 flex h-32 w-full items-center justify-center dark:border-b-[#2E2E2E] sm:h-18">
    <div class="flex flex-col h-full w-full items-center justify-between sm:flex-row sm:gap-12">
        <div class="flex h-full w-full items-center justify-center sm:pl-12 sm:justify-start">
            <a href="/">
                <p class="text-3xl text-primary font-mono text-center text-nowrap">Toby Nguyen_</p>
            </a>
        </div>
        <div class="flex gap-3 h-full h-full w-full items-center justify-center sm:pr-12 md:gap-6 sm:justify-end">
            {navbarItems.map(item => (
                <a href={item.url}>
                    <p class="text-xl navbar-item-text p-2 rounded-md duration-200">{item.name}</p>
                </a>
            ))}
            <a href="https://github.com/tobynguyen27" target="_blank" class="hidden sm:block">
                <button class="i-simple-icons-github text-xl navbar-item-text duration-200" />
            </a>
            <ThemeToggle />
        </div>
    </div>
</nav>
